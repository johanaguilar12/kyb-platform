// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Expediente {
  id            String         @id @default(cuid())
  rfc           String         @unique
  razonSocial   String         @map("razon_social")
  status        String         // 'draft' | 'pending_review' | 'approved' | 'rejected' | 'needs_update'
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  
  documents     Document[]
  satListChecks SATListCheck[]
  riskScore     RiskScore?
  auditLogs     AuditLog[]

  @@map("expedientes")
}

model Document {
  id              String     @id @default(cuid())
  expedienteId    String     @map("expediente_id")
  expediente      Expediente @relation(fields: [expedienteId], references: [id], onDelete: Cascade)
  type            String     // 'articles_of_incorporation' | 'legal_representative_id' | 'power_of_attorney' | 'proof_of_address' | 'rfc' | 'csf' | 'manifestation_under_protest' | 'controlling_party'
  name            String
  url             String?
  aiExtractedData Json?      @map("ai_extracted_data")
  issueDate       DateTime?  @map("issue_date")
  expirationDate  DateTime?  @map("expiration_date")
  isActive        Boolean    @default(true) @map("is_active")
  version         Int        @default(1)
  createdAt       DateTime   @default(now()) @map("created_at")

  @@index([expedienteId])
  @@index([type])
  @@map("documents")
}

model SATListCheck {
  id           String     @id @default(cuid())
  expedienteId String     @map("expediente_id")
  expediente   Expediente @relation(fields: [expedienteId], references: [id], onDelete: Cascade)
  rfc          String
  listType     String     @map("list_type") // 'list_69' | 'list_69_b' | 'list_69_b_bis' | 'list_49_bis'
  found        Boolean
  checkedAt    DateTime   @default(now()) @map("checked_at")
  source       String
  reference    String

  @@index([expedienteId])
  @@index([rfc])
  @@map("sat_list_checks")
}

model RiskScore {
  id              String     @id @default(cuid())
  expedienteId    String     @unique @map("expediente_id")
  expediente      Expediente @relation(fields: [expedienteId], references: [id], onDelete: Cascade)
  level           String     // 'safe' | 'review_required' | 'high_risk'
  score           Int
  factors         Json       // Array of RiskFactor
  explanation     String
  suggestedAction String     @map("suggested_action")
  calculatedAt    DateTime   @default(now()) @map("calculated_at")

  @@map("risk_scores")
}

model AuditLog {
  id           String      @id @default(cuid())
  expedienteId String?     @map("expediente_id")
  expediente   Expediente? @relation(fields: [expedienteId], references: [id], onDelete: SetNull)
  action       String      // AuditAction
  actor        String
  timestamp    DateTime    @default(now())
  beforeState  Json?       @map("before_state")
  afterState   Json?       @map("after_state")
  reason       String?

  @@index([expedienteId])
  @@index([action])
  @@map("audit_logs")
}

model SATListCache {
  id           String   @id @default(cuid())
  listType     String   @unique @map("list_type")
  data         Json
  downloadedAt DateTime @default(now()) @map("downloaded_at")
  source       String

  @@map("sat_list_caches")
}
